rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * AI Coach Connect Security Rules
     * 
     * Core Philosophy: 
     * This ruleset enforces a strict User-Ownership model. Access to data is gated by the 
     * user's authenticated UID, which must match the top-level document ID in the /users collection.
     *
     * Data Structure: 
     * All application data is hierarchical and nested under /users/{userId}. 
     * - /users/{userId}: The root profile for a user.
     * - /users/{userId}/coaching_sessions/{sessionId}: Sessions owned by the user.
     * - /users/{userId}/coaching_sessions/{sessionId}/feedback/{feedbackId}: Feedback for specific sessions.
     *
     * Key Security Decisions:
     * 1. Path-Based Authorization: We rely on the {userId} parameter in the document path to 
     *    verify ownership immediately without costly lookups.
     * 2. Denormalization for Authorization: The 'SessionFeedback' entity includes a denormalized 
     *    'userId' field. While authorization is primarily path-based, this field is validated 
     *    to ensure data integrity and support potential cross-collection queries in the future.
     * 3. Prototyping Flexibility: We strictly enforce "Who" can access data (authorization) 
     *    but remain flexible on "What" the data looks like (schema) to allow for rapid iteration.
     * 4. Relational Integrity: On creation and update, we ensure that internal ID fields 
     *    cannot be spoofed or changed to point to a different user.
     */

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combined check for ownership and document existence for state-changing operations.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the UserProfile entity. Users can only manage their own profile.
     * @path /users/{userId}
     * @allow (create) User 'abc' creates document '/users/abc' where data.id == 'abc'.
     * @deny (get) User 'abc' attempts to read '/users/def'.
     * @principle Ownership: Enforces that the document ID matches the User's Auth UID.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for CoachingSession entity. Nested under the user who owns the session.
       * @path /users/{userId}/coaching_sessions/{sessionId}
       * @allow (list) User 'abc' lists all sessions under '/users/abc/coaching_sessions'.
       * @deny (update) User 'abc' tries to change the 'userId' field of an existing session.
       * @principle Structural Segregation: Access is restricted by the parent path parameters.
       */
      match /coaching_sessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for SessionFeedback entity.
         * @path /users/{userId}/coaching_sessions/{sessionId}/feedback/{feedbackId}
         * @allow (create) User 'abc' submits feedback with a denormalized 'userId' field matching their UID.
         * @deny (create) User 'abc' submits feedback where 'userId' is 'def'.
         * @principle Authorization Independence: Uses denormalized userId to ensure integrity without parent lookups.
         */
        match /feedback/{feedbackId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}