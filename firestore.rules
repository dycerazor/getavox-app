/**
 * AI Coach Connect Security Rules
 *
 * CORE PHILOSOPHY:
 * This ruleset enforces a strict user-ownership model designed for rapid prototyping. 
 * While it allows for flexible data shapes to support iterative development, it 
 * maintains rigorous authorization checks. Every piece of data is tied to a specific 
 * user and is only accessible by that authenticated user.
 *
 * DATA STRUCTURE:
 * The data is organized hierarchically under a root `/users` collection:
 * - /users/{userId}: Individual user profile information.
 * - /users/{userId}/coachingSessions/{sessionId}: Coaching session logs owned by the user.
 *
 * KEY SECURITY DECISIONS:
 * 1. Ownership Enforcement: All paths include a `{userId}` parameter. Access is 
 *    granted only if the authenticated user's UID (`request.auth.uid`) matches 
 *    the `{userId}` in the document path.
 * 2. Authorization Independence: Critical ownership fields (like `userId` in 
 *    coaching sessions) are denormalized directly onto the documents. Rules 
 *    verify that these internal fields match the path and the user's identity, 
 *    ensuring security without needing to perform expensive cross-document lookups.
 * 3. Prototyping Flexibility: Rules do not enforce strict data types or field 
 *    presence for general content. However, they strictly enforce the immutability 
 *    of relational fields (like IDs) that anchor the security model.
 * 4. Robust Write Operations: All update and delete operations require the 
 *    document to exist and the user to be the confirmed owner.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by a signed-in user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Verifies if the user's authenticated UID matches the provided userId.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Verifies ownership and ensures the document exists for state-changing operations.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user profile documents.
     * @path /users/{userId}
     * @allow get: (get) User 'abc' requests their own profile /users/abc.
     * @deny create: (create) User 'abc' tries to create a profile for user 'xyz' at /users/xyz.
     * @principle Restricts access to a user's own data tree and validates relational integrity.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for individual coaching sessions belonging to a user.
       * @path /users/{userId}/coachingSessions/{sessionId}
       * @allow list: (list) User 'abc' queries their own sessions at /users/abc/coachingSessions.
       * @deny update: (update) User 'abc' attempts to change the 'userId' field of an existing session.
       * @principle Uses Authorization Independence by verifying internal ownership fields match the path.
       */
      match /coachingSessions/{sessionId} {
        allow get: if isOwner(userId);
        allow list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    // Explicitly deny any access to unspecified paths.
    match /{path=**} {
      allow read, write: if false;
    }
  }
}