rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the user is authenticated and matches the resource owner
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // User profiles: Only the owner can read/write their profile
    match /users/{userId} {
      allow read, write: if isOwner(userId);

      // Coaching sessions: Only the owner can manage their sessions
      match /coachingSessions/{sessionId} {
        allow read, write: if isOwner(userId);

        // Session messages: Only the owner can manage messages within their sessions
        match /sessionMessages/{messageId} {
          allow read, write: if isOwner(userId);
        }
      }
    }
  }
}